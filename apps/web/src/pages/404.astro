---
import Footer from '@/components/Footer.astro'
import Layout from '@/layouts/Layout.astro'
import * as m from '@/paraglide/messages'
---

<Layout title={m.page_not_found()}>
  <div class="min-h-screen flex flex-col items-center justify-center px-4 text-center gap-8" style="background: radial-gradient(ellipse at center, #1a003a 0%, #08001a 70%);">
    <h1 class="text-6xl sm:text-8xl">404</h1>
    <h2 class="text-3xl sm:text-4xl">{m.page_not_found()}</h2>
    <p class="text-xl" style="color: var(--color-silver);">{m.not_found_message()}</p>
    <a href="/" class="btn-magic">{m.back_to_home()}</a>
  </div>
  <Footer />
</Layout>
