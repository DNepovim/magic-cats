---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, locales } from '@/paraglide/runtime'

const currentLocale = getLocale()

const labelMap: Record<string, string> = {
  hu: 'Magyar',
  en: 'English',
  cs: 'Čeština',
  sk: 'Slovenčina',
}

// Strip current locale prefix to get the base path
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/'
let basePath = pathname
for (const locale of locales) {
  if (locale === 'hu') continue
  if (pathname === `/${locale}`) { basePath = '/'; break }
  if (pathname.startsWith(`/${locale}/`)) { basePath = pathname.slice(locale.length + 1); break }
}
---

<nav class="flex gap-4 text-sm pixel-text">
  {locales.map((lang) => (
    <a
      href={getRelativeLocaleUrl(lang, basePath)}
      class:list={[
        'transition-all duration-200',
        lang === currentLocale
          ? 'text-gold underline underline-offset-4'
          : 'text-silver opacity-50 hover:opacity-100 hover:text-gold',
      ]}
      style={lang === currentLocale ? 'text-shadow: 0 0 8px var(--color-gold)' : ''}
    >
      {labelMap[lang] ?? lang}
    </a>
  ))}
</nav>
