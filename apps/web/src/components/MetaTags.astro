---
import { getLocale } from '@/paraglide/runtime'
import * as m from '@/paraglide/messages'

const SITE_NAME = m.site_title()
const locale = getLocale()
const ogLocaleMap: Record<string, string> = { hu: 'hu_HU', en: 'en_US', cs: 'cs_CZ', sk: 'sk_SK' }
const ogLocale = ogLocaleMap[locale] ?? 'hu_HU'

type Props = {
  title: string;
  description?: string;
  image?: string;
  url: string;
};

const { title, description, url } = Astro.props;
const ogImage = Astro.props.image ? new URL(Astro.props.image, url).href : undefined;
---

<title>{title}</title>
{description && <meta name="description" content={description} />}
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={title} />
<meta property="og:type" content="website" />
<meta property="og:url" content={url} />
<meta property="og:locale" content={ogLocale} />
{description && <meta property="og:description" content={description} />}
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{ogImage && <meta name="twitter:image" content={ogImage} />}
