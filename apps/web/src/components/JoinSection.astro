---
import * as m from '@/paraglide/messages'
---

<section
  id="join"
  class="py-24 px-4 relative overflow-hidden"
  style="background: linear-gradient(-45deg, #08001a, #1a003a, #001a10, #1a0030, #000a1a); background-size: 600% 600%; animation: title-shimmer 10s ease infinite;"
>
  <div class="absolute inset-0 pointer-events-none opacity-30"
    style="background: repeating-linear-gradient(-45deg, transparent, transparent 30px, rgba(155,0,255,0.05) 30px, rgba(155,0,255,0.05) 60px);">
  </div>
  <div class="absolute top-4 left-6 pointer-events-none hidden md:block" style="transform: rotate(-15deg);">
    <img src="/cats/join1.jpg" alt="" width="80" height="80" loading="lazy"
      class="rounded-xl opacity-70" style="border: 2px solid var(--color-cyan); box-shadow: 0 0 10px var(--color-cyan);"
      onerror="this.style.display='none'" />
  </div>
  <div class="absolute top-8 right-8 pointer-events-none hidden md:block" style="transform: rotate(12deg);">
    <img src="/cats/join2.jpg" alt="" width="70" height="70" loading="lazy"
      class="rounded-xl opacity-70" style="border: 2px solid var(--color-magenta); box-shadow: 0 0 10px var(--color-magenta);"
      onerror="this.style.display='none'" />
  </div>
  <div class="absolute bottom-8 left-12 pointer-events-none hidden md:block" style="transform: rotate(8deg);">
    <img src="/cats/join3.jpg" alt="" width="90" height="90" loading="lazy"
      class="rounded-xl opacity-70" style="border: 2px solid var(--color-gold); box-shadow: 0 0 10px var(--color-gold);"
      onerror="this.style.display='none'" />
  </div>
  <div class="absolute bottom-6 right-10 pointer-events-none hidden md:block" style="transform: rotate(-10deg);">
    <img src="/cats/join4.jpg" alt="" width="75" height="75" loading="lazy"
      class="rounded-xl opacity-70" style="border: 2px solid var(--color-lime); box-shadow: 0 0 10px var(--color-lime);"
      onerror="this.style.display='none'" />
  </div>

  <div class="relative z-10 max-w-xl mx-auto text-center flex flex-col items-center gap-6">
    <span class="badge-new text-base px-4 py-2">🌟 EARLY ACCESS 🌟</span>

    <h2 style="font-family: var(--font-chunky); font-size: clamp(2.5rem, 7vw, 4.5rem); color: var(--color-gold); text-shadow: 0 0 20px var(--color-gold), 0 0 40px var(--color-magenta);">
      {m.join_title()}
    </h2>

    <p class="font-cursive text-2xl" style="color: var(--color-cyan); text-shadow: 0 0 10px var(--color-cyan);">
      {m.join_subtitle()}
    </p>

    <p class="font-marker text-lg blink" style="color: var(--color-magenta); transform: rotate(-1deg);">
      ⚠️ Limited spots available! ⚠️
    </p>

    <form
      class="flex flex-col sm:flex-row gap-3 w-full mt-2"
      method="POST"
      action="#"
    >
      <input
        type="email"
        name="email"
        placeholder={m.join_email_placeholder()}
        required
        class="flex-1 rounded-xl px-4 py-3 outline-none"
        style="background: rgba(18,0,48,0.9); color: var(--color-silver); font-family: var(--font-pixel); font-size: 0.95rem; border: 2px solid var(--color-magic); box-shadow: 0 0 10px var(--color-magic)44, inset 0 0 10px rgba(0,0,0,0.5);"
      />
      <button type="submit" class="btn-magic text-lg px-6 zoom-pulse">
        🐱 {m.join_cta()}
      </button>
    </form>

    <div class="flex gap-4 flex-wrap justify-center mt-2">
      <span class="font-retro text-xs" style="color: var(--color-lime);">✓ FREE</span>
      <span class="font-retro text-xs" style="color: var(--color-cyan);">✓ NO CREDIT CARD</span>
      <span class="font-retro text-xs" style="color: var(--color-gold);">✓ INSTANT ACCESS</span>
    </div>
  </div>
</section>
