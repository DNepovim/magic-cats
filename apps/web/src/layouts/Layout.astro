---
import Analytics from "@vercel/analytics/astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import PopupModals from "@/components/PopupModals.astro";
import MetaTags from "@/components/MetaTags.astro";
import "@/styles/global.css";
import { UMAMI_SITE_ID } from "astro:env/client";
import favicon from "@/favicon.svg";
import { getLocale } from "@/paraglide/runtime";
import * as m from "@/paraglide/messages";

const locale = getLocale();
const SITE_TITLE = m.site_title();

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const { title, description, image } = Astro.props;

const pageTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;

const config = {
  url: "https://cloud.umami.is/script.js",
  websiteId: UMAMI_SITE_ID,
} as const;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <meta name="generator" content={Astro.generator} />
    <MetaTags title={pageTitle} description={description} image={image} url={Astro.url.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline defer src={config.url} data-website-id={config.websiteId}
    ></script>
    <slot name="head" />
  </head>
  <body>
    <Analytics />
    <header class="flex justify-end px-6 py-4">
      <LanguageSwitcher />
    </header>
    <main>
      <slot />
    </main>
    <PopupModals />
  </body>
</html>
