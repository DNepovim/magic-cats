---
import * as m from '@/paraglide/messages'

const sparkles = Array.from({ length: 40 }, (_, i) => ({
  top: `${(i * 7 + 3) % 95}%`,
  left: `${(i * 13 + 5) % 97}%`,
  delay: `${(i * 0.23) % 3}s`,
  size: `${6 + (i % 5) * 2}px`,
  color: ['var(--color-gold)', 'var(--color-cyan)', 'var(--color-magenta)', 'var(--color-lime)', 'var(--color-electric)'][i % 5],
}))

const scatteredCats = [
  { top: '4%',  left: '2%',  w: 90,  h: 90,  rotate: '15deg',  seed: 'hero1', floatDuration: '5s'  },
  { top: '6%',  left: '78%', w: 110, h: 110, rotate: '-12deg', seed: 'hero2', floatDuration: '7s'  },
  { top: '30%', left: '88%', w: 80,  h: 80,  rotate: '22deg',  seed: 'hero3', floatDuration: '6s'  },
  { top: '68%', left: '82%', w: 100, h: 100, rotate: '-8deg',  seed: 'hero4', floatDuration: '8s'  },
  { top: '72%', left: '3%',  w: 95,  h: 95,  rotate: '10deg',  seed: 'hero5', floatDuration: '5.5s'},
  { top: '35%', left: '5%',  w: 75,  h: 75,  rotate: '-18deg', seed: 'hero6', floatDuration: '9s'  },
]

const marqueeText = '✦ Magic Cats ✦ Strategy ✦ Multiplayer ✦ Fantasy ✦ Battle ✦ Conquer ✦ '
const marqueeText2 = '🐱 JOIN NOW 🐱 FREE TO PLAY 🐱 10,000+ PLAYERS 🐱 WIN PRIZES 🐱 BE THE BEST 🐱 '
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden"
  style="background: radial-gradient(ellipse at 20% 30%, #2a005a 0%, #08001a 40%), radial-gradient(ellipse at 80% 70%, #001a3a 0%, transparent 60%);">

  {sparkles.map((s) => (
    <span
      class="sparkle absolute pointer-events-none"
      style={`top:${s.top}; left:${s.left}; animation-delay:${s.delay}; width:${s.size}; height:${s.size}; background:${s.color};`}
    />
  ))}

  {scatteredCats.map((cat) => (
    <div
      class="absolute hidden md:block pointer-events-none"
      style={`top:${cat.top}; left:${cat.left}; transform: rotate(${cat.rotate}); animation: float ${cat.floatDuration} ease-in-out infinite;`}
    >
      <img
        src={`https://cataas.com/cat?width=${cat.w}&height=${cat.h}&seed=${cat.seed}`}
        alt=""
        width={cat.w}
        height={cat.h}
        loading="eager"
        class="rounded-lg opacity-80"
        style="border: 2px solid var(--color-magic); box-shadow: 0 0 12px var(--color-magic);"
        onerror="this.style.display='none'"
      />
    </div>
  ))}

  <div class="absolute top-0 left-0 right-0 overflow-hidden py-2 z-20"
    style="background: linear-gradient(90deg, var(--color-cyan), var(--color-magic)); opacity:0.85;">
    <div class="flex whitespace-nowrap font-retro text-void text-xs"
      style="animation: marquee-reverse 15s linear infinite; width: max-content;">
      <span>{marqueeText2}{marqueeText2}{marqueeText2}&nbsp;&nbsp;</span>
      <span>{marqueeText2}{marqueeText2}{marqueeText2}&nbsp;&nbsp;</span>
    </div>
  </div>

  <div class="relative z-10 flex flex-col items-center text-center px-4 gap-6 mt-8">
    <span class="badge-new">⚡ NEW SEASON ⚡</span>

    <div class="relative">
      <div class="starburst" style="width:300px; height:300px; top:50%; left:50%; transform:translate(-50%,-50%) rotate(0deg);"></div>
      <img
        src="https://cataas.com/cat?width=220&height=220&seed=main-hero"
        alt={m.site_title()}
        width="220"
        height="220"
        loading="eager"
        class="relative float-anim rounded-full object-cover"
        style="border: 4px solid var(--color-gold); box-shadow: 0 0 30px var(--color-gold), 0 0 60px var(--color-magic), 0 0 100px var(--color-magenta);"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
      />
      <span class="text-9xl hidden">🐱</span>
    </div>

    <div class="flex flex-col items-center gap-1">
      <h1 class="title-shimmer leading-tight" style="font-family: var(--font-chunky); font-size: clamp(3rem, 10vw, 7rem);">
        {m.site_title()}
      </h1>
      <p class="rainbow-text font-marker text-2xl sm:text-3xl" style="transform: rotate(-2deg);">
        ~ {m.tagline()} ~
      </p>
    </div>

    <p class="font-cursive text-xl sm:text-2xl max-w-lg" style="color: var(--color-cyan); text-shadow: 0 0 12px var(--color-cyan);">
      {m.hero_subtitle()}
    </p>

    <div class="flex flex-wrap justify-center gap-4 items-center">
      <span class="pixel-text text-lg blink" style="color: var(--color-lime);">▶▶ {m.play_now()} ◀◀</span>
      <span class="font-retro text-xs" style="color: var(--color-silver);">10,000+ 🐱</span>
    </div>

    <div class="flex flex-wrap gap-4 justify-center items-center">
      <a href="#join" class="btn-magic wobble text-xl">
        ⚔️ {m.play_now()} ⚔️
      </a>
      <span class="badge-hot">🔥 HOT</span>
    </div>

    <div class="flex gap-2 mt-2">
      {'⭐⭐⭐⭐⭐'.split('').map(s => (
        <span class="text-2xl" style="animation: blink 1.5s step-end infinite; animation-delay: 0.3s;">⭐</span>
      ))}
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 overflow-hidden py-3 z-20"
    style="background: linear-gradient(135deg, var(--color-magic), var(--color-magenta)); opacity: 0.9;">
    <div class="flex whitespace-nowrap pixel-text text-void text-lg font-bold"
      style="animation: marquee 18s linear infinite; width: max-content;">
      <span>{marqueeText}{marqueeText}{marqueeText}&nbsp;&nbsp;</span>
      <span>{marqueeText}{marqueeText}{marqueeText}&nbsp;&nbsp;</span>
    </div>
  </div>
</section>
